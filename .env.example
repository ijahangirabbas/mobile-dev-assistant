# ─────────────────────────────────────────────
# Jina Embeddings
# ─────────────────────────────────────────────
JINA_API_KEY=your_jina_api_key_here
JINA_MODEL=jina-embeddings-v3
JINA_DIMENSIONS=1024
JINA_TASK=retrieval.passage

# ─────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Qdrant
# ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=course_chunks
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine
QDRANT_UPSERT_BATCH_SIZE=64

# ─────────────────────────────────────────────
# Chunking
# ─────────────────────────────────────────────
# Window size in seconds (each chunk = 15s of subtitles)
CHUNK_WINDOW_SECONDS=15

# ─────────────────────────────────────────────
# Embedding batching
# ─────────────────────────────────────────────
# Max texts per Jina API request
EMBEDDING_BATCH_SIZE=32

# ─────────────────────────────────────────────
# Course path
# ─────────────────────────────────────────────
# Root folder that CourseScanner will walk
COURSE_PATH=./class-subtitle
